<?xml version="1.0" encoding="utf-8"?>
<!--
    Main screen layout.
    - App title at the top.
    - Large circular SOS button centered on screen.
    - Countdown text below the button (hidden when not in use).
    - Status section at the bottom showing Bluetooth / Location state.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".MainActivity">

    <!-- ═══ App Title ═══ -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <!-- ═══ SOS Button ═══ -->
    <!--
        android:hapticFeedbackEnabled="true" gives vibration on touch events.
        The button itself handles a custom OnTouchListener for press-and-hold logic.
    -->
    <Button
        android:id="@+id/btnSOS"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:text="SOS"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/sos_button_background"
        android:elevation="8dp"
        android:hapticFeedbackEnabled="true"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintBottom_toTopOf="@id/tvCountdown"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVerticalBias="0.5" />

    <!-- ═══ Countdown Text ═══ -->
    <!--
        Shown only while the user is holding the SOS button (or during
        onEmergencySignalReceived). Hidden otherwise (INVISIBLE keeps space).
    -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/countdown_color"
        android:gravity="center"
        android:visibility="invisible"
        android:minHeight="56dp"
        app:layout_constraintTop_toBottomOf="@id/btnSOS"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- ═══ Status Card ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- "Status:" label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status:"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/status_neutral"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <!-- General status message (Waiting… / Holding… / SOS Triggered) -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_waiting"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/colorOnBackground"
                android:layout_marginTop="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Bluetooth status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bluetooth:"
                    android:textSize="15sp"
                    android:textColor="@color/status_neutral" />

                <TextView
                    android:id="@+id/tvBluetoothStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking…"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_warning"
                    tools:text="Enabled" />
            </LinearLayout>

            <!-- Location status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Location:"
                    android:textSize="15sp"
                    android:textColor="@color/status_neutral" />

                <TextView
                    android:id="@+id/tvLocationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking…"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_warning"
                    tools:text="Enabled" />
            </LinearLayout>

            <!-- ESP32-C3 BLE connection status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ESP32:"
                    android:textSize="15sp"
                    android:textColor="@color/status_neutral" />

                <TextView
                    android:id="@+id/tvEsp32Status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/esp32_status_scanning"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_warning"
                    tools:text="Scanning…" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
