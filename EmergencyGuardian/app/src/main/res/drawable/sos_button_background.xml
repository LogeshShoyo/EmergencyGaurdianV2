<?xml version="1.0" encoding="utf-8"?>
<!--
    Circular ripple background for the SOS button.
    Normal state: deep red circle.
    Pressed state: darker red, giving tactile feedback.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/sos_button_ripple">

    <!-- Clip the ripple to a circle -->
    <item android:id="@android:id/mask">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Normal background -->
    <item>
        <selector>
            <item android:state_pressed="true">
                <shape android:shape="oval">
                    <solid android:color="@color/sos_button_pressed" />
                    <stroke android:width="4dp" android:color="#FFFFFF" />
                </shape>
            </item>
            <item>
                <shape android:shape="oval">
                    <solid android:color="@color/sos_button_normal" />
                    <stroke android:width="4dp" android:color="#FFFFFF" />
                    <padding
                        android:bottom="4dp"
                        android:left="4dp"
                        android:right="4dp"
                        android:top="4dp" />
                </shape>
            </item>
        </selector>
    </item>

</ripple>
